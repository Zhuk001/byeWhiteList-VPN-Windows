<Window x:Class="ByeWhiteList.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:ByeWhiteList.Windows"
        Title="byeWhiteList" 
        Height="700" Width="450"
        MinHeight="500" MinWidth="350"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Shadows.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <local:PingTextConverter x:Key="PingTextConverter"/>
            <local:PingBrushConverter x:Key="PingBrushConverter"/>
            <local:SpeedTextConverter x:Key="SpeedTextConverter"/>
            <local:SpeedBrushConverter x:Key="SpeedBrushConverter"/>
            <local:ServerAddressConverter x:Key="ServerAddressConverter"/>

            <!-- Scrollable tab headers: do not shrink tabs when many -->
            <Style x:Key="ServersTabControlStyle" TargetType="{x:Type TabControl}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type TabControl}">
                            <Grid KeyboardNavigation.TabNavigation="Local">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="Transparent" Padding="0,0,0,0">
                                    <ScrollViewer x:Name="HeaderScrollViewer"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  CanContentScroll="True">
                                        <TabPanel IsItemsHost="True"
                                                  KeyboardNavigation.TabIndex="1"
                                                  Background="Transparent"
                                                  Margin="0,0,0,0"/>
                                    </ScrollViewer>
                                </Border>

                                <ContentPresenter Grid.Row="1"
                                                  ContentSource="SelectedContent"
                                                  Margin="0,8,0,0"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Стиль для кнопок управления окном -->
            <Style x:Key="WindowControlButton" TargetType="Button">
                <Setter Property="Width" Value="46"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#E81123"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Стиль для верхних иконок (добавить/обновить/настройки) -->
            <Style x:Key="TopIconButton" TargetType="Button">
                <Setter Property="Width" Value="34"/>
                <Setter Property="Height" Value="34"/>
                <Setter Property="Background" Value="#1E1E1E"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#3A3A3A"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="materialDesign:RippleAssist.Feedback" Value="#66FFFFFF"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#262626"/>
                        <Setter Property="BorderBrush" Value="#4A4A4A"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="#2E2E2E"/>
                        <Setter Property="BorderBrush" Value="#6A6A6A"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.5"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="MinimizeButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
                <Setter Property="Content" Value="&#xE921;"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#1E1E1E"/>
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
                <Setter Property="Content" Value="&#xE8BB;"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#E81123"/>
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Стиль для вкладок -->
            <Style TargetType="TabItem">
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Normal"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="Margin" Value="6,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Grid>
                                <Border x:Name="TabBorder"
                                        Background="#1A1A1A"
                                        Opacity="0.6"
                                        CornerRadius="16"/>
                                <ContentPresenter x:Name="ContentSite"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"
                                                  ContentSource="Header"
                                                  Margin="10,6"/>
                                <Border x:Name="SelectedIndicator"
                                        Height="4"
                                        Background="#4CAF50"
                                        CornerRadius="2"
                                        VerticalAlignment="Bottom"
                                        HorizontalAlignment="Center"
                                        Width="26"
                                        Margin="0,0,0,2"
                                        Visibility="Collapsed"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="TabBorder" Property="Opacity" Value="1"/>
                                    <Setter TargetName="TabBorder" Property="Background" Value="#2D2D2D"/>
                                    <Setter TargetName="SelectedIndicator" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TabBorder" Property="Opacity" Value="0.9"/>
                                    <Setter TargetName="TabBorder" Property="Background" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Стиль для карточки сервера -->
            <Style x:Key="ServerCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#1E1E1E"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="Padding" Value="14,10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#2D2D2D"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ServerListBoxStyle" TargetType="{x:Type ListBox}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
                <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
                <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
                <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
                <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
            </Style>

            <Style x:Key="ServerListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Focusable" Value="False"/>
                <EventSetter Event="MouseLeftButtonUp" Handler="ServerItem_LeftClick"/>
                <EventSetter Event="MouseRightButtonUp" Handler="ServerItem_RightClick"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border x:Name="Card"
                                    Style="{StaticResource ServerCardStyle}"
                                    BorderThickness="0"
                                    BorderBrush="Transparent">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Card" Property="Background" Value="#804CAF50"/>
                                    <Setter TargetName="Card" Property="BorderBrush" Value="#4CAF50"/>
                                    <Setter TargetName="Card" Property="BorderThickness" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <DataTemplate x:Key="ServerItemTemplate">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding DisplayNameText}"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="{Binding Ping, Converter={StaticResource PingTextConverter}}"
                                       Foreground="{Binding Ping, Converter={StaticResource PingBrushConverter}}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>

                            <TextBlock Text="{Binding ., Converter={StaticResource SpeedTextConverter}}"
                                       Foreground="{Binding ., Converter={StaticResource SpeedBrushConverter}}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding ., Converter={StaticResource ServerAddressConverter}}"
                               Foreground="Gray"
                               FontSize="10"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </DataTemplate>

            <!-- Контекстное меню (скруглённое) -->
            <Style x:Key="RoundedContextMenuStyle" TargetType="{x:Type ContextMenu}">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="HasDropShadow" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ContextMenu}">
                            <Border Background="#242424"
                                    BorderBrush="#3A3A3A"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="6">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.35" Color="Black"/>
                                </Border.Effect>
                                <StackPanel IsItemsHost="True" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="RoundedMenuItemStyle" TargetType="{x:Type MenuItem}">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type MenuItem}">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Стиль для чекбокса -->
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Margin" Value="0,0,15,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- Стиль для скроллбара -->
            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Width" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid>
                                <Track x:Name="PART_Track"
       IsDirectionReversed="True">
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="#555555" 
                                                            CornerRadius="4" 
                                                            Width="8"/>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0f0c29" Offset="0"/>
                <GradientStop Color="#302b63" Offset="0.5"/>
                <GradientStop Color="#24243e" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Background="#99000000" CornerRadius="20" Margin="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.5" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <!-- Верхняя панель -->
                <Border Grid.Row="0" 
                        Background="Transparent" 
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="byeWhiteList" 
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="White" 
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Margin="20,0,0,0"/>

                            <Grid HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Margin="0,6,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Верхний ряд: системные кнопки -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                                <!-- Действия -->
                                <Button x:Name="AddServerButton" 
                                        Style="{StaticResource TopIconButton}"
                                        Margin="0,0,8,0"
                                        Click="AddServerButton_Click"
                                        ToolTip="Добавить сервер">
                                    <materialDesign:PackIcon Kind="Plus"
                                                            Width="18" Height="18"
                                                            Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                </Button>

                                <Button x:Name="UpdateServersButton" 
                                        Style="{StaticResource TopIconButton}"
                                        Margin="0,0,8,0"
                                        Click="UpdateServersButton_Click"
                                        ToolTip="Обновить">
                                    <materialDesign:PackIcon Kind="Refresh"
                                                            Width="18" Height="18"
                                                            Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                </Button>

                                <Button x:Name="RoutingSettingsButton"
                                        Style="{StaticResource TopIconButton}"
                                        Margin="0,0,12,0"
                                        Click="RoutingSettingsButton_Click"
                                        ToolTip="Настройки">
                                    <materialDesign:PackIcon Kind="Cog"
                                                            Width="18" Height="18"
                                                            Foreground="#FFFFFF"/>
                                </Button>

                                <Button x:Name="MinimizeToTrayButton" 
                                        Style="{StaticResource MinimizeButton}"
                                        Width="32" Height="32"
                                        FontSize="16"
                                        Margin="0,0,6,0"
                                        Click="MinimizeToTrayButton_Click"
                                        ToolTip="Свернуть в трей">
                                    <Button.Content>
                                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                    </Button.Content>
                                </Button>

                                <Button x:Name="CloseButton" 
                                        Style="{StaticResource CloseButton}"
                                        Width="32" Height="32"
                                        FontSize="16"
                                        Margin="0"
                                        Click="CloseButton_Click"
                                        ToolTip="Закрыть">
                                    <Button.Content>
                                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- VPN Button -->
                <Button x:Name="VpnButton" Grid.Row="1" 
                        Width="160" Height="160"
                        Margin="0,10,0,10"
                        HorizontalAlignment="Center"
                        Background="#F44336"
                        Click="VpnButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="80">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                                </Border.Effect>
                                <TextBlock x:Name="textBlock" 
                                           Text="VPN&#10;ВЫКЛ" 
                                           Foreground="White" 
                                           FontSize="22" FontWeight="Bold"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Вкладки с серверами -->
                <TabControl x:Name="ServersTabControl" Grid.Row="2"
                            Margin="16,0,16,8"
                            Background="Transparent"
                            BorderThickness="0"
                            Style="{StaticResource ServersTabControlStyle}"
                            SelectionChanged="ServersTabControl_SelectionChanged">
                    <TabControl.Resources>
                        <Style TargetType="TabPanel">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </TabControl.Resources>
                </TabControl>

                <!-- Статус бар -->
                <Border Grid.Row="3" 
                        Background="#1A1A1A" 
                        Padding="15,0">
                    <Border.CornerRadius>
                        <CornerRadius BottomLeft="20" BottomRight="20"/>
                    </Border.CornerRadius>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="StatusText" 
                                   Text="Готов к работе"
                                   Foreground="#CCCCCC" 
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="SpeedDownloadText" 
                                       Text="⬇ 0 KB/s" 
                                       Foreground="#4CAF50" 
                                       FontSize="11"
                                       Margin="10,0,5,0"/>
                            <TextBlock x:Name="SpeedUploadText" 
                                       Text="⬆ 0 KB/s" 
                                       Foreground="#F44336" 
                                       FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid x:Name="TutorialOverlay"
              Panel.ZIndex="1000"
              Visibility="Collapsed"
              IsHitTestVisible="False">
            <Canvas>
                <Border x:Name="TutorialHighlight"
                        Width="40"
                        Height="40"
                        CornerRadius="12"
                        BorderBrush="#FF4CAF50"
                        BorderThickness="3"
                        Background="#22FFFFFF"/>

                <Border x:Name="TutorialBubble"
                        Width="320"
                        Background="#EE1F1F1F"
                        BorderBrush="#4CAF50"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12">
                    <TextBlock x:Name="TutorialText"
                               Foreground="White"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </Border>
            </Canvas>
        </Grid>
    </Grid>
</Window>
