<Window x:Class="ByeWhiteList.Windows.SettingsMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Topmost="True"
        Foreground="White">
    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="#2B2B2B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#303030"/>
                    <Setter Property="BorderBrush" Value="#4A4A4A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#383838"/>
                    <Setter Property="BorderBrush" Value="#6A6A6A"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#01000000" MouseDown="Overlay_MouseDown">
        <Border Background="#242424"
                BorderBrush="#3A3A3A"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16"
                Width="360"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                MouseDown="Card_MouseDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Настройки" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Выберите раздел:" Foreground="#BBBBBB" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="30"
                            Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            Cursor="Hand"
                            Click="Close_Click"
                            ToolTip="Закрыть">
                        <TextBlock Text="✕" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource MenuButton}" Click="News_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📰" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Новости" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButton}" Click="Routing_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧭" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Правила маршрутизации" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButton}" Click="Speedtest_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Speedtest" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButton}" Click="AppUpdate_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⬇" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Обновление приложения" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButton}" Click="Feedback_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✉" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Обратная связь" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MenuButton}" Click="StartTutorial_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎓" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Запустить обучение" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
